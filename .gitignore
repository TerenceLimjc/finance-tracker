# ─── Runtime data (never commit) ─────────────────────────────────────────────
database/
uploads/
logs/

# ─── Dependencies ─────────────────────────────────────────────────────────────
node_modules/

# ─── Build output ─────────────────────────────────────────────────────────────
# (workspace-level .gitignore files cover frontend/dist and backend/dist)

# ─── Environment files ────────────────────────────────────────────────────────
# Root-level only — workspace .env files are handled per-workspace below
.env
.env.local
.env.*.local

# ─── OS artefacts ─────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# ─── Editor / IDE ─────────────────────────────────────────────────────────────
.idea/
*.sublime-project
*.sublime-workspace
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─── Misc ─────────────────────────────────────────────────────────────────────
*.tsbuildinfo
