# Backend environment variables
# Copy this file to backend/.env and fill in values

PORT=3001
FRONTEND_PORT=3000
DATABASE_PATH=../database/finance.db
UPLOADS_PATH=../uploads
LOGS_PATH=../logs
NODE_ENV=development

# ── Tier 2 AI categorisation ──────────────────────────────────────────────────
# Local LLM takes precedence over OpenAI when LOCAL_LLM_BASE_URL is set.
# Supports Ollama, LM Studio, llama.cpp, or any OpenAI-compatible local server.
#
# Setup with Ollama:
#   brew install ollama && ollama serve
#   ollama pull qwen2.5:3b      # fast, excellent JSON (~2GB)
#   ollama pull phi3.5:latest   # balanced quality/speed (~2.2GB)
#   ollama pull llama3.2:3b     # good general purpose (~2GB)
#
# LOCAL_LLM_BASE_URL=http://localhost:11434/v1
# LOCAL_LLM_MODEL=qwen2.5:3b    # default; use qwen2.5:1.5b for lower memory
# LOCAL_LLM_API_KEY=local

# LM Studio alternative:
# LOCAL_LLM_BASE_URL=http://localhost:1234/v1
# LOCAL_LLM_MODEL=lmstudio-community/Qwen2.5-3B-Instruct-GGUF

# Optional: OpenAI API key (used when LOCAL_LLM_BASE_URL is not set)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
