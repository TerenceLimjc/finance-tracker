{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Dev: Start All",
            "type": "shell",
            "command": "npm run dev",
            "group": "build",
            "isBackground": true,
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "problemMatcher": []
        },
        {
            "label": "Dev: Frontend only",
            "type": "shell",
            "command": "npm run dev",
            "options": {
                "cwd": "${workspaceFolder}/frontend"
            },
            "isBackground": true,
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "problemMatcher": []
        },
        {
            "label": "Dev: Backend only",
            "type": "shell",
            "command": "npm run dev",
            "options": {
                "cwd": "${workspaceFolder}/backend"
            },
            "isBackground": true,
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "problemMatcher": []
        },
        {
            "label": "Build: All",
            "type": "shell",
            "command": "npm run build",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always"
            },
            "problemMatcher": [
                "$tsc"
            ]
        },
        {
            "label": "Typecheck: Frontend",
            "type": "shell",
            "command": "npm run typecheck",
            "options": {
                "cwd": "${workspaceFolder}/frontend"
            },
            "problemMatcher": [
                "$tsc"
            ],
            "presentation": {
                "reveal": "always"
            }
        },
        {
            "label": "Typecheck: Backend",
            "type": "shell",
            "command": "npm run typecheck",
            "options": {
                "cwd": "${workspaceFolder}/backend"
            },
            "problemMatcher": [
                "$tsc"
            ],
            "presentation": {
                "reveal": "always"
            }
        },
        {
            "label": "Install: All dependencies",
            "type": "shell",
            "command": "npm install",
            "presentation": {
                "reveal": "always"
            },
            "problemMatcher": []
        }
    ]
}